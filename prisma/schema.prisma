generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Cyclist {
  id                   String             @id @default(uuid())
  supabaseUserId       String             @unique
  email                String             @unique
  fullName             String?
  stravaId             String?            @unique
  stravaAccessToken    String?
  stravaRefreshToken   String?
  stravaConnectedAt    DateTime?
  isAdmin              Boolean            @default(false)
  isAmbassador         Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  stravaTokenExpiresAt DateTime?
  activities           Activity[]
  ambassadorProfile    AmbassadorProfile?
  invitationsCreated   ClubInvitation[]   @relation("InvitationCreator")
  clubMemberships      ClubMembership[]
  clubsCreated         Club[]             @relation("ClubCreator")
  bikeTypes            CyclistBikeType[]
  profile              CyclistProfile?

  @@index([supabaseUserId])
  @@index([stravaId])
  @@map("cyclists")
}

model CyclistProfile {
  id                String   @id @default(uuid())
  cyclistId         String   @unique
  practiceStyle     String?
  preferGrip        Int      @default(5)
  preferEndurance   Int      @default(5)
  preferLightness   Int      @default(5)
  preferVersatility Int      @default(5)
  primaryBikeType   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  cyclist           Cyclist  @relation(fields: [cyclistId], references: [id], onDelete: Cascade)

  @@map("cyclist_profiles")
}

model CyclistBikeType {
  id                    String   @id @default(uuid())
  cyclistId             String
  bikeType              String
  isPrimary             Boolean  @default(false)
  manualMonthlyDistance Float?
  manualElevationGain   Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  cyclist               Cyclist  @relation(fields: [cyclistId], references: [id], onDelete: Cascade)

  @@unique([cyclistId, bikeType])
  @@index([cyclistId])
  @@map("cyclist_bike_types")
}

model Activity {
  id               String   @id @default(uuid())
  cyclistId        String
  stravaId         String?  @unique
  bikeType         String
  activityDate     DateTime
  distance         Float
  elevationGain    Float
  movingTime       Int
  averageSpeed     Float?
  terrainAsphalt   Float    @default(0)
  terrainOffroad   Float    @default(0)
  terrainMixed     Float    @default(0)
  weatherCondition String?
  isManual         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  cyclist          Cyclist  @relation(fields: [cyclistId], references: [id], onDelete: Cascade)

  @@index([cyclistId, bikeType])
  @@index([activityDate])
  @@index([stravaId])
  @@map("activities")
}

model Tire {
  id                  String           @id @default(uuid())
  globalId            String           @unique
  brand               String
  productType         String
  rangeName           String
  webProductName      String
  designation         String
  compatibleBikeTypes String
  useCases            String
  terrainTypes        String
  rubberTech          String?
  casingTech          String?
  reinforcementTech   String?
  width               Int?
  diameter            Int?
  weight              Int?
  minPressure         Float?
  maxPressure         Float?
  isEBikeReady        Boolean          @default(false)
  isDiscontinued      Boolean          @default(false)
  discontinuedDate    DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  ambassadorTires     AmbassadorTire[]

  @@index([compatibleBikeTypes])
  @@index([useCases])
  @@index([terrainTypes])
  @@map("tires")
}

model Club {
  id              String           @id @default(uuid())
  name            String
  description     String?
  isMultiBikeType Boolean          @default(true)
  bikeTypeFilter  String?
  creatorId       String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  invitations     ClubInvitation[]
  memberships     ClubMembership[]
  creator         Cyclist          @relation("ClubCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@map("clubs")
}

model ClubMembership {
  id        String   @id @default(uuid())
  clubId    String
  cyclistId String
  isManager Boolean  @default(false)
  joinedAt  DateTime @default(now())
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  cyclist   Cyclist  @relation(fields: [cyclistId], references: [id], onDelete: Cascade)

  @@unique([clubId, cyclistId])
  @@index([clubId])
  @@index([cyclistId])
  @@map("club_memberships")
}

model ClubInvitation {
  id         String   @id @default(uuid())
  clubId     String
  creatorId  String
  token      String   @unique
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  club       Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  creator    Cyclist  @relation("InvitationCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([clubId])
  @@map("club_invitations")
}

model AmbassadorProfile {
  id               String           @id @default(uuid())
  cyclistId        String           @unique
  bio              String
  discipline       String
  skillLevel       String
  photoUrl         String?          // Main profile photo URL
  photos           String[]         @default([]) // Additional photos URLs (gallery)
  articleContent   String?          // Rich text article content (HTML)
  showRidingData   Boolean          @default(false)
  featuredSegments String?
  isFeatured       Boolean          @default(false)
  displayOrder     Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  cyclist          Cyclist          @relation(fields: [cyclistId], references: [id], onDelete: Cascade)
  tires            AmbassadorTire[]

  @@map("ambassador_profiles")
}

model AmbassadorTire {
  id           String            @id @default(uuid())
  ambassadorId String
  tireId       String
  bikeType     String
  testimonial  String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  ambassador   AmbassadorProfile @relation(fields: [ambassadorId], references: [id], onDelete: Cascade)
  tire         Tire              @relation(fields: [tireId], references: [id], onDelete: Cascade)

  @@unique([ambassadorId, bikeType])
  @@index([ambassadorId])
  @@index([tireId])
  @@map("ambassador_tires")
}
