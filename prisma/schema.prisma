generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Cyclist {
  id                      String                    @id @default(uuid())
  supabaseUserId          String                    @unique
  email                   String                    @unique
  fullName                String?
  stravaId                String?                   @unique
  stravaAccessToken       String?
  stravaRefreshToken      String?
  stravaConnectedAt       DateTime?
  isAdmin                 Boolean                   @default(false)
  isAmbassador            Boolean                   @default(false)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  stravaTokenExpiresAt    DateTime?
  activities              Activity[]
  ambassadorProfile       AmbassadorProfile?
  club_event_participants club_event_participants[]
  club_events             club_events[]
  invitationsCreated      ClubInvitation[]          @relation("InvitationCreator")
  clubMemberships         ClubMembership[]
  club_routes             club_routes[]
  clubsCreated            Club[]                    @relation("ClubCreator")
  bikeTypes               CyclistBikeType[]
  profile                 CyclistProfile?

  @@index([supabaseUserId])
  @@index([stravaId])
  @@map("cyclists")
}

model CyclistProfile {
  id                String   @id @default(uuid())
  cyclistId         String   @unique
  practiceStyle     String?
  preferGrip        Int      @default(5)
  preferEndurance   Int      @default(5)
  preferLightness   Int      @default(5)
  preferVersatility Int      @default(5)
  primaryBikeType   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  cyclist           Cyclist  @relation(fields: [cyclistId], references: [id], onDelete: Cascade)

  @@map("cyclist_profiles")
}

model CyclistBikeType {
  id                    String   @id @default(uuid())
  cyclistId             String
  bikeType              String
  isPrimary             Boolean  @default(false)
  manualMonthlyDistance Float?
  manualElevationGain   Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  cyclist               Cyclist  @relation(fields: [cyclistId], references: [id], onDelete: Cascade)

  @@unique([cyclistId, bikeType])
  @@index([cyclistId])
  @@map("cyclist_bike_types")
}

model Activity {
  id               String   @id @default(uuid())
  cyclistId        String
  stravaId         String?  @unique
  bikeType         String
  activityDate     DateTime
  distance         Float
  elevationGain    Float
  movingTime       Int
  averageSpeed     Float?
  polyline         String?  // Encoded polyline from Strava for map display
  startLatitude    Float?   // Start coordinates
  startLongitude   Float?
  terrainAsphalt   Float    @default(0)
  terrainOffroad   Float    @default(0)
  terrainMixed     Float    @default(0)
  weatherCondition String?
  isManual         Boolean  @default(false)
  isFeatured       Boolean  @default(false) // For ambassadors to feature routes
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  cyclist          Cyclist  @relation(fields: [cyclistId], references: [id], onDelete: Cascade)

  @@index([cyclistId, bikeType])
  @@index([activityDate])
  @@index([stravaId])
  @@index([cyclistId, isFeatured])
  @@map("activities")
}

// A Tire is a product MODEL (one per Global ID). Its physical declinations
// (sizes, weights, pressures, EAN…) live in TireVariant.
model Tire {
  id                  String           @id @default(uuid())
  globalId            String           @unique

  // --- Product identity (constant within a Global ID) ---
  brand               String
  productType         String // TYRE | TUBE | TUBULAR
  cycleType           String // MTB | ROAD | CITY
  segment             String
  rangeName           String // "Web Range Name" (web)
  rangeInternal       String // "Range (Internal)" (internal)
  compatibleBikeTypes String // "CYCLE TYPE WEB"
  useCases            String // "Use"

  // --- Product technologies ---
  rubberTech          String?
  casingTech          String?
  treadPatternTech    String?
  sidewallType        String?
  sealing             String?
  rimType             String?
  fitting             String?

  // Product gallery images (managed via admin). First one is the card thumbnail.
  images              String[]         @default([])

  // --- Denormalized aggregates (computed at seed time from variants) ---
  terrainTypes        String // union of all variant terrains
  minWeight           Int? // lightest variant weight
  isEBikeReady        Boolean          @default(false)
  isDiscontinued      Boolean          @default(false) // true only if all variants are discontinued

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  variants            TireVariant[]
  ambassadorTires     AmbassadorTire[]

  @@index([compatibleBikeTypes])
  @@index([useCases])
  @@index([terrainTypes])
  @@map("tires")
}

// A physical declination of a Tire product: a specific size / build.
model TireVariant {
  id                   String    @id @default(uuid())
  tireId               String
  tire                 Tire      @relation(fields: [tireId], references: [id], onDelete: Cascade)

  designation          String // "Designation (Internal)" (internal)
  webProductName       String // "Web Product Designation" (web)
  bead                 String?
  eanCode              String?
  widthEtrto           String?
  diameterEtrto        String?
  widthMm              Int? // "Web Width (mm)"
  diameterMm           Int? // "Web Diameter (mm)"
  weight               Int?
  minPressure          Float?
  maxPressure          Float?
  tpi                  String?
  terrainTypes         String // exact terrains for this variant
  reinforcementTech    String?
  sidewallColor        String?
  treadPatternColor    String?
  recommendedInnerTube String?
  discontinuedDate     DateTime?
  isDiscontinued       Boolean   @default(false)

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([tireId])
  @@map("tire_variants")
}

model Club {
  id                String           @id @default(uuid())
  name              String
  description       String?
  isMultiBikeType   Boolean          @default(true)
  bikeTypeFilter    String?
  creatorId         String
  inviteCode        String           @unique @default(dbgenerated("gen_random_uuid()"))
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  isMichelinPartner Boolean          @default(false)
  isPremium         Boolean          @default(false)
  location          String?
  city              String?
  region            String?
  foundedYear       Int?
  club_events       club_events[]
  invitations       ClubInvitation[]
  memberships       ClubMembership[]
  club_routes       club_routes[]
  creator           Cyclist          @relation("ClubCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@map("clubs")
}

model ClubMembership {
  id        String   @id @default(uuid())
  clubId    String
  cyclistId String
  isManager Boolean  @default(false)
  joinedAt  DateTime @default(now())
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  cyclist   Cyclist  @relation(fields: [cyclistId], references: [id], onDelete: Cascade)

  @@unique([clubId, cyclistId])
  @@index([clubId])
  @@index([cyclistId])
  @@map("club_memberships")
}

model ClubInvitation {
  id         String   @id @default(uuid())
  clubId     String
  creatorId  String
  token      String   @unique
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  club       Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  creator    Cyclist  @relation("InvitationCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([clubId])
  @@map("club_invitations")
}

model AmbassadorProfile {
  id               String           @id @default(uuid())
  cyclistId        String           @unique
  bio              String
  discipline       String
  skillLevel       String
  showRidingData   Boolean          @default(false)
  featuredSegments String?
  isFeatured       Boolean          @default(false)
  displayOrder     Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  articleContent   String?
  photoUrl         String?
  photos           String[]         @default([])
  cyclist          Cyclist          @relation(fields: [cyclistId], references: [id], onDelete: Cascade)
  tires            AmbassadorTire[]

  @@map("ambassador_profiles")
}

model AmbassadorTire {
  id           String            @id @default(uuid())
  ambassadorId String
  tireId       String
  bikeType     String
  testimonial  String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  ambassador   AmbassadorProfile @relation(fields: [ambassadorId], references: [id], onDelete: Cascade)
  tire         Tire              @relation(fields: [tireId], references: [id], onDelete: Cascade)

  @@unique([ambassadorId, bikeType])
  @@index([ambassadorId])
  @@index([tireId])
  @@map("ambassador_tires")
}

model club_event_participants {
  id          String      @id @default(uuid())
  eventId     String
  cyclistId   String
  confirmed   Boolean     @default(true)
  joinedAt    DateTime    @default(now())
  cyclists    Cyclist     @relation(fields: [cyclistId], references: [id], onDelete: Cascade)
  club_events club_events @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, cyclistId])
  @@index([cyclistId])
  @@index([eventId])
}

model club_events {
  id                      String                    @id @default(uuid())
  clubId                  String
  title                   String
  description             String?
  discipline              String
  eventDate               DateTime
  location                String?
  departureLabel          String?
  distance                Float?
  elevation               Float?
  level                   String?
  bikeType                String?
  isOfficial              Boolean                   @default(false)
  requiresLicense         Boolean                   @default(false)
  createdById             String
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  club_event_participants club_event_participants[]
  clubs                   Club                      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  cyclists                Cyclist                   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([createdById])
}

model club_routes {
  id             String   @id @default(uuid())
  clubId         String
  title          String
  distanceKm     Float
  elevationGain  Int
  discipline     String
  level          String?
  thumbnailUrl   String?
  completedCount Int      @default(0)
  createdById    String
  createdAt      DateTime @default(now())
  clubs          Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  cyclists       Cyclist  @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([createdById])
}
